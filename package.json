{
  "name": "astra",
  "version": "1.0.10",
  "description": "Astra — Steam-dark desktop chat app",
  "main": "./out/main/index.js",
  "author": "Codez",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "make": "electron-vite build && electron-builder --win --config",
    "make:dir": "electron-vite build && electron-builder --win --dir --config"
  },
  "dependencies": {
    "@giphy/js-fetch-api": "^5.8.0",
    "@giphy/react-components": "^10.1.2",
    "@supabase/supabase-js": "^2.105.3",
    "electron-updater": "^6.8.3",
    "material-symbols": "^0.44.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/forms": "^0.5.9",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "canvas": "^3.2.3",
    "convert-svg-to-png": "^0.7.1",
    "cspell": "^10.0.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-store": "^8.2.0",
    "electron-vite": "^6.0.0-beta.1",
    "eslint": "^10.3.0",
    "png-to-ico": "^3.0.1",
    "pngjs": "^3.4.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  },
  "build": {
    "appId": "com.astra.app",
    "productName": "Astra",
    "artifactName": "${productName}.Setup.${version}.${ext}",
    "asar": true,
    "directories": {
      "output": "out/make/${version}",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "!out/renderer/**/*.map",
      "!out/main/**/*.map",
      "!out/preload/**/*.map",
      "!out/make/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "asarUnpack": [
      "resources/icons/*.png",
      "resources/sound-effects/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "ZheyUse",
      "repo": "walkie-chattie"
    }
  }
}
